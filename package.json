{
  "name": "mini-apps",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo of small, self-contained mini-apps. Each builds to a single Store-compatible .tsx file.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "check-contract": "node scripts/check-contract.mjs",
    "build": "npm run build --workspaces --if-present",
    "verify": "npm run verify --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  }
}
