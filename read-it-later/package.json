{
  "name": "read-it-later",
  "version": "0.1.0",
  "private": true,
  "description": "Offline reading list and Web Share Target — save links, notes and snippets via IndexedDB.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "node ../scripts/check-contract.mjs src/read-it-later.tsx",
    "build": "npm run typecheck && npm run test && npm run check && mkdir -p dist && cp src/read-it-later.tsx dist/read-it-later.tsx",
    "verify": "npm run build && vite build"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
